VITE_API_BASE_URL=http://localhost:8000/api

# Storage backend for trip history & settings.
#   local     -> browser localStorage (default; great for development)
#   supabase  -> per-driver cloud sync (requires Supabase wiring; see
#                src/storage/supabaseProvider.ts)
VITE_STORAGE_PROVIDER=local

# Supabase (only needed when VITE_STORAGE_PROVIDER=supabase)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
